page {
  min-height: 100%;
  background: linear-gradient(180deg, #f7fcff 0%, #eef7fb 100%);
  color: #16324f;
  font-size: 28rpx;
}

.page-shell {
  padding: 32rpx 24rpx 48rpx;
}

.hero-card,
.panel,
.action-card,
.team-card,
.stat-card,
.log-card {
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(80, 148, 190, 0.18);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(70, 121, 158, 0.08);
}

.hero-card,
.panel {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.muted {
  color: #5f7892;
}

.primary-btn {
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1ea7c5 0%, #2f73ff 100%);
  color: #fff;
}

.danger-btn {
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff8b6b 0%, #ff5d5d 100%);
  color: #fff;
}
