.screen-shell {
  min-height: 100vh;
  padding: 48rpx 36rpx;
  background:
    radial-gradient(circle at top left, rgba(35, 183, 255, 0.18), transparent 36%),
    radial-gradient(circle at bottom right, rgba(50, 220, 136, 0.18), transparent 34%),
    #081a2f;
  color: #f5fbff;
}

.screen-title {
  font-size: 56rpx;
  font-weight: 700;
}

.screen-leader {
  margin: 18rpx 0 42rpx;
  font-size: 32rpx;
  color: #8cd9ff;
}

.screen-grid {
  display: grid;
  gap: 26rpx;
}

.screen-card {
  padding: 34rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.14);
}

.screen-team-name {
  font-size: 36rpx;
}

.screen-score {
  margin: 12rpx 0;
  font-size: 72rpx;
  font-weight: 700;
}

.screen-member {
  color: rgba(245, 251, 255, 0.72);
}
