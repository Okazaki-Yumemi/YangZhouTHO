<view class="page-shell">
  <view class="hero-card">
    <view class="section-title">管理员后台</view>
    <view class="muted">当前页面提供导出和后续管理入口骨架，权限校验在云函数端执行。</view>
    <button class="danger-btn" loading="{{loading}}" bindtap="onExportTap">导出当前数据</button>
  </view>

  <view class="panel" wx:if="{{exportData}}">
    <view class="section-title">导出概览</view>
    <view class="muted">用户：{{exportData.users.length}} 条</view>
    <view class="muted">队伍：{{exportData.teams.length}} 条</view>
    <view class="muted">行动日志：{{exportData.action_logs.length}} 条</view>
  </view>
</view>
