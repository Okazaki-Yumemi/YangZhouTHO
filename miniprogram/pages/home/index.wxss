.mini-nav {
  margin-top: 24rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(80, 148, 190, 0.14);
  gap: 20rpx;
}

.action-item {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.action-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.team-brief {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.team-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: #eaf6ff;
}

.team-brief-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
}

.result-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx 24rpx;
  background: rgba(8, 22, 40, 0.42);
}

.result-modal {
  width: 100%;
  padding: 30rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 171, 117, 0.2), transparent 30%),
    rgba(255, 255, 255, 0.98);
  box-shadow: 0 24rpx 60rpx rgba(8, 22, 40, 0.24);
}

.result-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.result-copy {
  color: #31506c;
  line-height: 1.6;
  margin-bottom: 18rpx;
}

.result-stat {
  margin-bottom: 8rpx;
  color: #17314d;
}

.event-card {
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fff7ef 0%, #fff 100%);
  border: 1px solid rgba(255, 163, 92, 0.24);
  text-align: center;
}

.event-head {
  font-size: 24rpx;
  color: #ab5935;
  letter-spacing: 2rpx;
}

.event-image {
  width: 100%;
  height: 320rpx;
  margin: 18rpx 0 10rpx;
}

.event-character {
  color: #7a90ab;
  font-size: 24rpx;
}

.event-title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 8rpx 0 12rpx;
}

.event-copy {
  color: #324a66;
  line-height: 1.7;
}

.event-effect {
  margin-top: 16rpx;
  color: #bf5f2d;
  font-weight: 600;
}
