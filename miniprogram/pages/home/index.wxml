<view class="page-shell">
  <view class="hero-card" wx:if="{{user}}">
    <view class="section-title">{{user.display_name}}</view>
    <view class="muted">所属队伍：{{user.team === 'cirno' ? '琪露诺队' : '大妖精队'}}</view>
    <view class="muted">当前称号：{{user.title}}</view>
    <view class="muted">个人探索进度：{{user.score}}</view>
    <view class="muted">当前体力：{{user.stamina}}</view>
    <view wx:if="{{buffCountdown}}" class="muted">恢复 buff 剩余：{{buffCountdown}}</view>
    <button class="primary-btn mini-nav" bindtap="goProfile">查看个人信息</button>
  </view>

  <view class="panel">
    <view class="section-title">阵营进度</view>
    <view wx:for="{{teams}}" wx:key="id" class="stat-row">
      <view class="team-brief">
        <image class="team-avatar" src="{{item.portrait_url}}" mode="aspectFill" />
        <view>
          <view>{{item.name}}</view>
          <view class="muted team-brief-sub">领队：{{item.character_name}}</view>
        </view>
      </view>
      <text>{{item.member_count}} 人 / {{item.total_score}} 分</text>
    </view>
  </view>

  <view class="section-title">当前可执行行动</view>
  <view wx:for="{{actions}}" wx:key="_id" class="action-card action-item">
    <view class="action-name">{{item.name}}</view>
    <view class="muted">{{item.description}}</view>
    <button
      class="primary-btn"
      data-action-id="{{item._id}}"
      loading="{{loadingActionId === item._id}}"
      bindtap="onActionTap"
    >
      消耗 {{item.stamina_cost}} 体力执行
    </button>
  </view>

  <view wx:if="{{resultModal.visible}}" class="result-overlay" bindtap="closeResultModal">
    <view class="result-modal" catchtap="noop">
      <view class="result-title">{{resultModal.title}}</view>
      <view class="result-copy">{{resultModal.actionText}}</view>
      <view class="result-stat">{{resultModal.scoreText}}</view>
      <view class="result-stat">{{resultModal.teamText}}</view>
      <view class="result-stat">{{resultModal.staminaText}}</view>

      <view wx:if="{{resultModal.randomEventTriggered}}" class="event-card">
        <view class="event-head">你触发了一个红魔馆事件</view>
        <image class="event-image" src="{{resultModal.eventImage}}" mode="aspectFit" />
        <view class="event-character">{{resultModal.eventCharacterName}}</view>
        <view class="event-title">{{resultModal.eventTitle}}</view>
        <view class="event-copy">{{resultModal.eventDescription}}</view>
        <view class="event-effect">{{resultModal.eventEffectText}}</view>
      </view>

      <button class="primary-btn" bindtap="closeResultModal">收起</button>
    </view>
  </view>
</view>
